# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase DB (for Drizzle — not used at runtime, only for migrations)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# App URL (set to your production domain on Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (use test keys during development)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs — use either naming convention:
STRIPE_PILOT_MONTHLY_PRICE_ID=price_...
STRIPE_PILOT_ANNUAL_PRICE_ID=price_...
